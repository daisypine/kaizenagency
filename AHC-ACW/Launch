<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kaizen — Adapt Rebrand Launch</title>
<style>
  :root{--ink:#14160F;--ink-soft:#5C6052;--paper:#F4F5EF;--surface:#FFFFFF;--line:#E4E6DB;--lime:#C3E84C;--lime-deep:#7E9C1F;--done-bg:#F4F8E3;--warn-bg:#FBE7C7;--warn-ink:#9A6A12;--shadow:0 1px 2px rgba(20,22,15,.04),0 8px 24px rgba(20,22,15,.05);--radius:14px;}
  *{box-sizing:border-box} html{scroll-behavior:smooth}
  body{margin:0;background:var(--paper);color:var(--ink);font-family:system-ui,-apple-system,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;font-size:16px;line-height:1.5;-webkit-font-smoothing:antialiased}
  .topbar{position:sticky;top:0;z-index:20;background:var(--ink);color:#fff;border-bottom:3px solid var(--lime)}
  .topbar-inner{max-width:940px;margin:0 auto;padding:14px 22px;display:flex;flex-wrap:wrap;align-items:center;gap:14px 18px}
  .brand{display:flex;align-items:center;gap:11px;margin-right:auto}
  .pill{display:inline-block;background:#fff;color:var(--ink);font-weight:800;letter-spacing:.04em;font-size:12px;padding:5px 11px;border-radius:999px;border:2px solid var(--ink);box-shadow:0 2px 0 var(--lime)}
  .brand h1{font-size:15px;font-weight:700;margin:0;letter-spacing:.01em}
  .brand .eyebrow{display:block;font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--lime);margin-bottom:1px}
  .btn{border:1px solid #3a3e30;background:#1f221a;color:#fff;font-family:inherit;font-size:13px;font-weight:600;padding:8px 13px;border-radius:9px;cursor:pointer}
  .btn:hover{border-color:var(--lime)} .btn:focus-visible{outline:2px solid var(--lime);outline-offset:2px}
  .progress-wrap{max-width:940px;margin:0 auto;padding:0 22px 14px}
  .progress-row{display:flex;align-items:center;gap:14px}
  .progress-track{flex:1;height:10px;background:#2b2f24;border-radius:999px;overflow:hidden}
  .progress-fill{height:100%;width:0;background:var(--lime);border-radius:999px;transition:width .3s ease}
  .progress-pct{font-size:13px;font-weight:700;color:#fff;min-width:112px;text-align:right}
  .progress-pct b{color:var(--lime)}
  .save-flag{font-size:11px;color:var(--lime);opacity:0;transition:opacity .2s;font-weight:700;letter-spacing:.04em}
  .save-flag.show{opacity:1}
  main{max-width:940px;margin:0 auto;padding:24px 22px 80px}
  .intro{color:var(--ink-soft);font-size:14.5px;margin:2px 0 18px;max-width:720px}
  .intro b{color:var(--ink)}
  .ledger{background:#1b1d16;color:#e9ebe0;border-radius:var(--radius);padding:0;margin-bottom:16px;overflow:hidden;border:1px solid #2b2f24}
  .ledger summary{cursor:pointer;list-style:none;padding:13px 18px;font-size:13px;font-weight:700;letter-spacing:.04em;display:flex;align-items:center;gap:9px}
  .ledger summary::-webkit-details-marker{display:none}
  .ledger summary .lk{color:var(--lime)}
  .ledger .body{padding:2px 18px 16px;font-size:13px;line-height:1.6}
  .ledger .row{padding:9px 0;border-top:1px solid #2b2f24}
  .ledger .row:first-child{border-top:none}
  .ledger b{color:#fff} .ledger .lime{color:var(--lime);font-weight:700} .ledger .muted{color:#9a9d8c}
  .section{background:var(--surface);border:1px solid var(--line);border-radius:var(--radius);box-shadow:var(--shadow);margin-bottom:16px;overflow:hidden}
  .section-head{display:flex;align-items:center;gap:13px;padding:16px 20px;cursor:pointer;border-bottom:1px solid transparent;user-select:none}
  .section.open .section-head{border-bottom-color:var(--line)}
  .sec-letter{flex:none;width:34px;height:34px;border-radius:9px;display:grid;place-items:center;background:var(--ink);color:var(--lime);font-weight:800;font-size:15px}
  .section.complete .sec-letter{background:var(--lime);color:var(--ink)}
  .sec-title{font-weight:700;font-size:16px;margin:0;flex:1;display:flex;align-items:center;gap:9px;flex-wrap:wrap}
  .sec-flag{font-size:10px;font-weight:800;letter-spacing:.06em;text-transform:uppercase;padding:3px 8px;border-radius:6px;background:var(--warn-bg);color:var(--warn-ink)}
  .sec-count{font-size:12.5px;font-weight:700;color:var(--ink-soft);font-variant-numeric:tabular-nums}
  .sec-count.done{color:var(--lime-deep)}
  .chev{flex:none;width:18px;height:18px;color:var(--ink-soft);transition:transform .2s}
  .section.open .chev{transform:rotate(90deg)}
  .items{padding:6px 20px 14px;display:none} .section.open .items{display:block}
  .item{display:flex;gap:13px;align-items:flex-start;padding:11px 12px;border-radius:10px;margin:2px -6px;transition:background .15s}
  .item:hover{background:#fafbf5} .item.checked{background:var(--done-bg)}
  .item input{position:absolute;opacity:0;width:1px;height:1px}
  .box{flex:none;margin-top:1px;width:21px;height:21px;border-radius:6px;border:2px solid #c5c8ba;background:#fff;display:grid;place-items:center;transition:all .15s}
  .box svg{width:13px;height:13px;opacity:0;transform:scale(.6);transition:all .15s}
  .item.checked .box{background:var(--lime);border-color:var(--lime-deep)}
  .item.checked .box svg{opacity:1;transform:scale(1)}
  .item input:focus-visible + .box{outline:2px solid var(--ink);outline-offset:2px}
  .label-wrap{flex:1;cursor:pointer}
  .label-main{font-size:14.5px;line-height:1.4} .item.checked .label-main{color:var(--ink-soft)}
  .label-hint{display:block;font-size:12.5px;color:var(--ink-soft);margin-top:3px;line-height:1.45}
  footer{max-width:940px;margin:0 auto;padding:0 22px 60px;color:var(--ink-soft);font-size:12.5px}
  @media (max-width:640px){.progress-pct{min-width:auto}}
  @media (prefers-reduced-motion: reduce){*{transition:none !important;scroll-behavior:auto}}
  @media print{body{background:#fff}.topbar{position:static;border-bottom:2px solid #000}.no-print,.chev,.btn,.save-flag{display:none !important}.ledger{color:#000;background:#fff;border:1px solid #999}.ledger .body{display:block!important}.progress-track{border:1px solid #000}.section{break-inside:avoid;box-shadow:none;border-color:#999}.items{display:block !important}.item:hover{background:none}}
</style>
</head>
<body>
<header class="topbar">
  <div class="topbar-inner">
    <div class="brand"><span class="pill">KAIZEN</span><div><span class="eyebrow">Rebrand · target July 1</span><h1>Adapt Rebrand Launch</h1></div></div>
    <button class="btn no-print" id="resetBtn">Reset</button>
    <button class="btn no-print" id="printBtn">Print</button>
  </div>
  <div class="progress-wrap no-print"><div class="progress-row">
    <div class="progress-track"><div class="progress-fill" id="fill"></div></div>
    <span class="progress-pct"><b id="pctNum">0%</b> · <span id="countNum">0/0</span></span>
    <span class="save-flag" id="saveFlag">Saved</span>
  </div></div>
</header>
<main>
  <p class="intro">Pre-launch foundation for the Adapt Health Clinic → <b>Adapt Chiropractic and Wellness</b> rebrand. The foundational SEO work — keeping your Google rankings and listings consistent through the move — comes first, with branding and print further down. Check items off as you go; progress saves in your browser.</p>
  <details class="ledger" open>
    <summary><span class="lk">◆</span> Project facts (reference)</summary>
    <div class="body">
      <div class="row"><b>Domain change</b> · adapthealthclinic.com → <span class="lime">adaptchiropracticwellness.com</span> · <span class="muted">redirects carry your current Google rankings over to the new site</span></div>
      <div class="row"><b>Short domain</b> · adaptcw.com · <span class="muted">main email (info@adaptcw.com) + all promotional materials, redirects to the main site</span></div>
      <div class="row"><b>Domains</b> · all 3 stay registered · <span class="muted">adapthealthclinic.com also redirects in, so past patients still find you</span></div>
      <div class="row"><b>NAP</b> · Adapt Chiropractic and Wellness · 1475 S Bascom Ave, Suite 104, Campbell, CA · (408) 673-2432 · <span class="muted">confirm exact ZIP, then lock one format everywhere</span></div>
      <div class="row"><b>Target launch</b> · <span class="lime">July 1</span></div>
    </div>
  </details>
  <div id="sections"></div>
</main>
<footer>Kaizen Agency · Adapt rebrand launch checklist. Built to protect your Google rankings and keep your name consistent everywhere through the move. Progress saves locally in this browser once the file is opened directly or hosted.</footer>
<script>
const DATA=[
  {id:"1",title:"Lock the foundation",items:[
    {t:"Confirm final business name everywhere: Adapt Chiropractic and Wellness"},
    {t:"Lock NAP in ONE exact format — identical everywhere, no variations",h:"Name: Adapt Chiropractic and Wellness · Address: 1475 S Bascom Ave, Suite 104, Campbell, CA (confirm exact ZIP + suite format) · Phone: (408) 673-2432"},
    {t:"Set adaptchiropracticwellness.com as the main website address"},
    {t:"Confirm all domains registered",h:"adaptchiropracticwellness.com (site), adaptcw.com (email + short redirect), adapthealthclinic.com (kept for redirects + legacy email)"},
  ]},
  {id:"2",title:"Domain migration & redirects",items:[
    {t:"Build the redirect map — every old URL → its matching new URL",h:"Maps each old page to its new home so your current Google rankings carry over. Worth starting early — it's the most detailed piece."},
    {t:"Use 301 (permanent) redirects, not 302"},
    {t:"Whole-domain redirect: adapthealthclinic.com → adaptchiropracticwellness.com"},
    {t:"adaptcw.com → adaptchiropracticwellness.com (301)"},
    {t:"No redirect chains or loops — old → new in one hop"},
    {t:"Preserve URL structure where possible (no city slugs, per our convention)"},
    {t:"Update all internal links to the new domain"},
    {t:"Update canonical tags to the new domain"},
    {t:"SSL cert active on the new domain"},
    {t:"robots.txt not blocking the new site"},
    {t:"Regenerate XML sitemap with the new URLs"},
    {t:"New domain property in Search Console + submit sitemap"},
    {t:"Use GSC Change of Address tool if applicable"},
    {t:"Test every redirect after go-live"},
  ]},
  {id:"3",title:"Google Business Profile",items:[
    {t:"Update business name → Adapt Chiropractic and Wellness"},
    {t:"Update website URL → adaptchiropracticwellness.com"},
    {t:"NAP matches the locked format exactly"},
    {t:"Refresh description, services, and photos with new branding"},
    {t:"Watch for re-verification — name changes can trigger it"},
  ]},
  {id:"4",title:"Citations & directories",items:[
    {t:"Build a master list of every place the old name/URL lives"},
    {t:"Yelp"},
    {t:"Apple Maps + Bing Places"},
    {t:"Data aggregators (Data Axle, Foursquare, etc.)"},
    {t:"Healthcare directories (Healthgrades, etc.)"},
    {t:"Insurance / provider directories"},
    {t:"Social profiles (@adaptchiropracticwellness)"},
    {t:"Update name + URL + NAP on each — and track what's done"},
  ]},
  {id:"5",title:"Email / Google Workspace",items:[
    {t:"Add adaptcw.com into the existing Workspace"},
    {t:"Set up info@, dr.mike@, michaeld@ on the new domain"},
    {t:"Keep adapthealthclinic.com as an alias so old mail still lands"},
    {t:"Confirm no new seats / no cost change"},
    {t:"Update email signatures with new branding + links"},
  ]},
  {id:"6",title:"Website content / on-page SEO",items:[
    {t:"Logo, brand name, and colors updated site-wide"},
    {t:"Title tags, meta descriptions, H1s updated with the new name"},
    {t:"LocalBusiness schema updated (name + NAP)"},
    {t:"Footer NAP updated"},
    {t:"About / team pages updated"},
  ]},
  {id:"7",title:"Brand & print assets",items:[
    {t:"Business cards (in progress w/ Basel)"},
    {t:"Tri-fold brochure (in progress w/ Basel)"},
    {t:"Launch announcement graphics (social)"},
    {t:"Print uses adaptcw.com; online listings use the full domain"},
  ]},
  {id:"8",title:"Launch day",items:[
    {t:"Flip redirects live"},
    {t:"Push the new site live on adaptchiropracticwellness.com"},
    {t:"Submit sitemap + request indexing in GSC"},
    {t:"Spot-check the most important old URLs redirect correctly"},
    {t:"Update GBP"},
  ]},
  {id:"9",title:"Post-launch monitoring (first 2–4 weeks)",items:[
    {t:"Watch GSC for crawl errors / 404s"},
    {t:"Monitor rankings + organic traffic vs. baseline"},
    {t:"Confirm all redirects still firing"},
    {t:"Watch GBP for re-verification"},
    {t:"Check Analytics for traffic continuity"},
  ]},
];
const STORE_KEY="kz_adapt_rebrand_v1";
const CHECK=`<svg viewBox="0 0 24 24" fill="none" stroke="#14160F" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
const CHEV=`<svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>`;
let store=loadStore();
function loadStore(){try{return JSON.parse(localStorage.getItem(STORE_KEY))||{checks:{}};}catch(e){return{checks:{}};}}
function saveStore(){try{localStorage.setItem(STORE_KEY,JSON.stringify(store));flashSaved();}catch(e){}}
function render(){
  const root=document.getElementById("sections");root.innerHTML="";
  DATA.forEach((sec,si)=>{
    const el=document.createElement("section");el.className="section"+(si===0?" open":"");el.dataset.sec=sec.id;
    el.innerHTML=`<div class="section-head" role="button" tabindex="0" aria-expanded="${si===0}"><span class="sec-letter">${sec.id}</span><h2 class="sec-title">${sec.title}${sec.flag?`<span class="sec-flag">${sec.flag}</span>`:""}</h2><span class="sec-count" data-count="${sec.id}">0/0</span>${CHEV}</div><div class="items">${sec.items.map((it,ii)=>{const id=`${sec.id}-${ii}`;return `<label class="item" data-id="${id}"><input type="checkbox" id="${id}"><span class="box">${CHECK}</span><span class="label-wrap"><span class="label-main">${it.t}</span>${it.h?`<span class="label-hint">${it.h}</span>`:""}</span></label>`;}).join("")}</div>`;
    root.appendChild(el);
    const head=el.querySelector(".section-head");
    head.addEventListener("click",()=>toggle(el,head));
    head.addEventListener("keydown",e=>{if(e.key==="Enter"||e.key===" "){e.preventDefault();toggle(el,head);}});
  });
  root.querySelectorAll('input[type="checkbox"]').forEach(cb=>cb.addEventListener("change",onCheck));
}
function toggle(el,head){el.classList.toggle("open");head.setAttribute("aria-expanded",el.classList.contains("open"));}
function onCheck(e){if(e.target.checked)store.checks[e.target.id]=true;else delete store.checks[e.target.id];saveStore();applyState();}
function applyState(){
  const ch=store.checks;let done=0,total=0;
  document.querySelectorAll('.item').forEach(it=>{const cb=it.querySelector('input');const on=!!ch[cb.id];cb.checked=on;it.classList.toggle("checked",on);total++;if(on)done++;});
  DATA.forEach(sec=>{let d=0,t=0;sec.items.forEach((_,ii)=>{t++;if(ch[`${sec.id}-${ii}`])d++;});const b=document.querySelector(`[data-count="${sec.id}"]`);b.textContent=`${d}/${t}`;b.classList.toggle("done",t>0&&d===t);b.closest(".section").classList.toggle("complete",t>0&&d===t);});
  const pct=total?Math.round(done/total*100):0;
  document.getElementById("fill").style.width=pct+"%";
  document.getElementById("pctNum").textContent=pct+"%";
  document.getElementById("countNum").textContent=`${done}/${total}`;
}
let ft;function flashSaved(){const f=document.getElementById("saveFlag");f.classList.add("show");clearTimeout(ft);ft=setTimeout(()=>f.classList.remove("show"),1100);}
document.getElementById("resetBtn").addEventListener("click",()=>{if(confirm("Clear all checked items?")){store.checks={};saveStore();applyState();}});
document.getElementById("printBtn").addEventListener("click",()=>window.print());
render();applyState();
</script>
</body>
</html>
